# ================================
# SERVER
# ================================
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1

# ================================
# DATABASE (MySQL)
# ================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=vitechs_db
DB_USER=root
DB_PASSWORD=your_password
